# Minimal profile (DB + embedding only)
# Copy to .env when you want the quickest startup path.

DATABASE_URL=postgres://postgres:postgres@localhost:7888/gnosis

# Written automatically by `bun run bootstrap` based on your OS.
# GNOSIS_EMBED_COMMAND=services/embedding/.venv/bin/embed

GNOSIS_EMBEDDING_DIMENSION=384
GNOSIS_DEDUPE_THRESHOLD=0.9

# Optional: override Bun command path
# GNOSIS_BUN_COMMAND=bun
