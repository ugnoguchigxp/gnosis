    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "1.7.3",
    "@types/pg": "^8.11.5",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.1"
  }
}
