{
  "name": "gnosis",
  "version": "0.1.0",
  "description": "VibeCoding Memory & Knowledge Graph MCP Server",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
