{
  "name": "gnosis",
  "version": "0.2.0",
  "description": "VibeCoding Memory & Knowledge Graph MCP Server",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ugnoguchigxp/gnosis.git"
  },
  "homepage": "https://github.com/ugnoguchigxp/gnosis",
  "bugs": {
    "url": "https://github.com/ugnoguchigxp/gnosis/issues"
  },
  "keywords": ["mcp", "ai", "agent", "knowledge-graph", "rag", "pgvector", "bun", "local-llm"],
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "bootstrap": "bun run scripts/bootstrap.ts",
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "llmharness:local-llm": "bun run src/integrations/llmharness-local-llm.ts",
    "db:init": "bun run setup_db.ts && bun run db:migrate && bun run db:seed",
    "db:generate": "drizzle-kit generate",
    "db:meta-check": "bun run src/scripts/db-meta-check.ts",
    "db:reconcile": "bun run src/scripts/db-reconcile-migrations.ts",
    "db:migrate": "bun run db:meta-check && bun run db:reconcile && drizzle-kit migrate",
    "db:seed": "bun run src/db/seed.ts",
    "db:audit": "bun run src/scripts/db-audit.ts",
    "db:push": "drizzle-kit push",
    "guidance:import": "bun run src/scripts/import-guidance.ts",
    "monitor:snapshot": "bun run src/scripts/monitor-snapshot.ts --json",
    "monitor:detail": "bun run src/scripts/monitor-detail.ts --json",
    "monitor:dev": "bun run --cwd apps/monitor tauri:dev",
    "review": "bun run src/scripts/review.ts",
    "gemma4": "./scripts/gemma4",
    "bonsai": "./scripts/bonsai",
    "bedrock": "./scripts/bedrock",
    "openai": "./scripts/openai",
    "lint": "biome check .",
    "format": "biome format --write .",
    "smoke": "bun run scripts/smoke.ts",
    "verify:fast": "bun run scripts/verify.ts fast",
    "test:coverage": "bun test --coverage --coverage-include='src/adapters/**' --coverage-include='src/domain/**' --coverage-include='src/mcp/tools/**' --coverage-include='src/services/**' --coverage-include='src/utils/**'",
    "test:coverage:summary": "bun run scripts/coverage-summary.ts",
    "test:failure-path": "bun run scripts/test-failure-path.ts",
    "test:related": "bun run scripts/test-related.ts",
    "test:flaky-check": "bun run scripts/test-flaky-check.ts",
    "test:integration:local": "bun run scripts/test-integration-local.ts",
    "test:phase3:batch": "bun test test/scripts/batch-process.phase3.integration.test.ts",
    "verify": "bun run scripts/verify.ts",
    "verify:strict": "bun run scripts/verify.ts strict",
    "observe:worker": "bun run scripts/observe-worker.ts",
    "observe:review": "bun run scripts/observe-review.ts",
    "hooks:setup": "bun run scripts/setup-hooks.ts --apply-project-rules",
    "maintenance": "bun run src/scripts/maintenance.ts",
    "task:knowflow:once": "bun run src/services/knowflow/cli.ts run-once --strict-complete --verbose",
    "task:episode:consolidate": "bun run src/scripts/monitor-episodes.ts consolidate --strict --verbose",
    "task:verify:operation": "bun run scripts/verify-task-operation.ts",
    "typecheck": "tsc --noEmit",
    "monorepo:setup": "./scripts/setup-services.sh",
    "release": "bun run verify && git tag -a v$(node -p \"require('./package.json').version\") -m \"Release v$(node -p \"require('./package.json').version\")\" && echo 'Tagged. Run git push --tags to publish.'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nicia-ai/typegraph": "^0.3.0",
    "drizzle-orm": "^0.45.2",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "parse-diff": "^0.11.1",
    "pg": "^8.16.3",
    "simple-git": "^3.36.0",
    "yaml": "^2.8.3",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@biomejs/biome": "1.7.3",
    "@types/pg": "^8.11.5",
    "bun-types": "1.3.12",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.1",
    "typescript": "^6.0.2"
  }
}
