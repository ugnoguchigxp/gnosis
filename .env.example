# Database Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:7888/gnosis

# LLM Configuration
# Path to LLM script (e.g. gemma4, bonsai)
GNOSIS_LLM_SCRIPT=scripts/gemma4
GNOSIS_BONSAI_SCRIPT=scripts/bonsai
# LocalLlm Project Path
GNOSIS_LOCAL_LLM_PATH=services/local-llm

# Cloud LLM Provider (choose one: openai, azure-openai, bedrock, anthropic, google)
GNOSIS_REVIEW_LLM_PROVIDER=bedrock

# --- OpenAI ---
# Uncomment and set to use the `openai` command
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5-mini

# --- Azure OpenAI ---
# Uncomment and set GNOSIS_REVIEW_LLM_PROVIDER=azure-openai to use
# AZURE_OPENAI_API_KEY=your_azure_api_key
# AZURE_OPENAI_MODEL=gpt-5-mini
# GNOSIS_REVIEW_LLM_API_BASE_URL=https://your-resource.openai.azure.com
# Azure OpenAI API version (default: 2025-04-01-preview). Only needed to override.
# GNOSIS_REVIEW_LLM_API_VERSION=

# --- AWS Bedrock ---
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=ap-northeast-1
GNOSIS_REVIEW_LLM_BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-6
GNOSIS_REVIEW_LLM_BEDROCK_INFERENCE_PROFILE_ID=jp.anthropic.claude-sonnet-4-6

# Embedding Configuration
# GNOSIS_EMBED_COMMAND should match your OS-specific venv executable path.
GNOSIS_EMBEDDING_DIMENSION=384
GNOSIS_DEDUPE_THRESHOLD=0.9

# Worker & LLM Specifics
LOCAL_LLM_API_BASE_URL=http://127.0.0.1:44448
LOCAL_LLM_API_PATH=/v1/chat/completions
LOCAL_LLM_MODEL=gemma-4-e4b-it
LOCAL_LLM_ENABLE_CLI_FALLBACK=true
KNOWFLOW_LLM_MAX_CONCURRENCY=1
KNOWFLOW_LLM_QUEUE_TIMEOUT_MS=900000
KNOWFLOW_LLM_QUEUE_NAME=local-llm

# KnowFlow Worker Configuration
KNOWFLOW_WORKER_TASK_TIMEOUT_MS=600000
KNOWFLOW_WORKER_POLL_INTERVAL_MS=1000
KNOWFLOW_WORKER_MAX_CONSECUTIVE_ERRORS=5
KNOWFLOW_WORKER_MAX_QUERIES_PER_TASK=10
KNOWFLOW_WORKER_CRON_RUN_WINDOW_MS=3600000

# Health Check Configuration
KNOWFLOW_HEALTH_CHECK_TIMEOUT_MS=5000

# Graph & Memory
GNOSIS_GRAPH_SIMILARITY_THRESHOLD=0.8
GNOSIS_GRAPH_MAX_PATH_HOPS=5
GNOSIS_MEMORY_RETRIES=3
GNOSIS_MEMORY_RETRY_WAIT_MULTIPLIER=1000

# LLM & Harness
GNOSIS_LLM_MAX_BUFFER_BYTES=10485760
GNOSIS_LLM_DEFAULT_TIMEOUT_MS=45000

# Guidance
GUIDANCE_MAX_ZIPS=1000

# Log Directories
GNOSIS_CLAUDE_LOG_DIR=/path/to/.claude/projects
GNOSIS_ANTIGRAVITY_LOG_DIR=/path/to/.gemini/antigravity/brain

# Budgets
USER_BUDGET=12
CRON_BUDGET=6
CRON_RUN_BUDGET=30

# Guidance (Optional)
# GUIDANCE_PROJECT=my-project
# GUIDANCE_ENABLED=true

# Monitor & Graph Configuration
GRAPH_SNAPSHOT_MAX_ENTITIES=1000
GRAPH_SNAPSHOT_MAX_RELATIONS=2000
GRAPH_SNAPSHOT_MAX_COMMUNITIES=100
