# This file is kept for backward compatibility.
# Recommended templates:
#   - .env.minimal      (minimal startup)
#   - .env.local-llm    (minimal + local llm)
#   - .env.cloud-review (minimal + cloud review)
#
# Quick start:
#   cp .env.minimal .env
#   bun run bootstrap

# Minimal defaults
DATABASE_URL=postgres://postgres:postgres@localhost:7888/gnosis
GNOSIS_EMBEDDING_DIMENSION=384
GNOSIS_DEDUPE_THRESHOLD=0.9

# Optional local LLM defaults (enable only when needed)
LOCAL_LLM_API_BASE_URL=http://127.0.0.1:44448
LOCAL_LLM_API_PATH=/v1/chat/completions
LOCAL_LLM_MODEL=gemma-4-e4b-it
LOCAL_LLM_ENABLE_CLI_FALLBACK=true
GNOSIS_LLM_SCRIPT=scripts/gemma4
GNOSIS_BONSAI_SCRIPT=scripts/bonsai
GNOSIS_LOCAL_LLM_PATH=services/local-llm

# Optional cloud review defaults (choose provider + credentials)
GNOSIS_REVIEW_LLM_PROVIDER=openai
# MCP tool exposure:
# - primary (default): Agent-First tool surface only
# - all: expose legacy/advanced tools for compatibility clients (e.g. Antigravity legacy flows)
# GNOSIS_MCP_TOOL_EXPOSURE=all
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5-mini
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=ap-northeast-1
