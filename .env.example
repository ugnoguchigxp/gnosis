# Database Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:7888/gnosis

# Azure OpenAI / Bedrock CLI defaults
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_MODEL=...
# GNOSIS_REVIEW_LLM_API_BASE_URL=https://your-resource.openai.azure.com

# AWS Bedrock Configuration
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# Log Directories
GNOSIS_CLAUDE_LOG_DIR=/path/to/.claude/projects
GNOSIS_ANTIGRAVITY_LOG_DIR=/Users/your-user/.gemini/antigravity/brain

# Web Search
# BRAVE_SEARCH_API_KEY=...
